# Server
PORT=8080
SERVICE_NAME=dexter-transport-service
SERVICE_DESCRIPTION=DX transport Service
GIN_MODE=release
SHUTDOWN_TIMEOUT=300s
RUN_LOCAL=true
# true : Logs will print in colorful, readable dev format.
# false : LLogs will output in JSON structured format for production.
DEBUG_MODE=true
CONSOLE_FORMAT=true
APP_ENV=local

# Swagger / Docs
API_DOCS=true
API_DOCS_SCHEMA=http
API_DOCS_HOST=localhost:8080
API_DOCS_VERSION=v1.0.0